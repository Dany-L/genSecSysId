# .gitignore for Python sysid package

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# Virtual Environments
# ============================================================================
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# ============================================================================
# IDEs and Editors
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.spyproject/
.ropeproject/

# ============================================================================
# Testing
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
coverage.xml
*.cover
*.log

# ============================================================================
# Jupyter Notebook
# ============================================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================================
# Data Files (Keep structure, ignore data)
# ============================================================================
# Ignore all data files
data/**/*.csv
data/**/*.npy
data/**/*.mat
data/**/*.h5
data/**/*.hdf5
data/**/*.pkl
data/**/*.pickle

# Keep directory structure
!data/.gitkeep
!data/prepared/.gitkeep
!data/prepared/train/.gitkeep
!data/prepared/test/.gitkeep
!data/prepared/validation/.gitkeep
!data/raw/.gitkeep

# ============================================================================
# Generated Outputs (Training & Evaluation)
# ============================================================================
# Model checkpoints and trained models
models/
*.pt
*.pth
*.ckpt
*.h5
*.pb

# Training outputs
outputs/
logs/
runs/
checkpoints/

# Evaluation results
evaluation_results/
analysis_results/
predictions/
debug_*/

# Normalizers (if you want to keep them, comment this out)
**/normalizer.json

# ============================================================================
# MLflow
# ============================================================================
mlruns/
mlartifacts/
.mlruns/

# ============================================================================
# TensorBoard
# ============================================================================
events.out.tfevents.*
tensorboard_logs/
tb_logs/

# ============================================================================
# Documentation builds
# ============================================================================
docs/_build/
docs/_static/
docs/_templates/
site/

# ============================================================================
# OS Specific
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
*.bak
*.swp
*~.nib
*.log.*

# ============================================================================
# Environment and Config (be careful with secrets!)
# ============================================================================
.env
.env.local
.env.*.local
*.secret
secrets/

# ============================================================================
# Package Manager
# ============================================================================
.python-version
Pipfile.lock
poetry.lock
pdm.lock
